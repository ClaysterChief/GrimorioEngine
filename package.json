{
  "name": "grimorio-engine",
  "version": "2.0.3",
  "description": "ESC Labs PS1 UI Framework — pure CSS + vanilla JS",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "style": "css/grimorio.css",
  "main": "js/grimorio.js",
  "exports": {
    ".": "./css/grimorio.css",
    "./js": "./js/grimorio.js"
  },
  "files": [
    "css/grimorio.css",
    "css/grimorio.min.css",
    "js/grimorio.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cleancss -o packages/css/grimorio.min.css packages/css/grimorio.css && node -e \"const fs=require('fs');fs.mkdirSync('css',{recursive:true});fs.copyFileSync('packages/css/grimorio.css','css/grimorio.css');fs.copyFileSync('packages/css/grimorio.min.css','css/grimorio.min.css')\"",
    "serve": "npx serve ."
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": ["css", "framework", "ps1", "crt", "ui", "esc-labs"],
  "author": "ESC Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClaysterChief/GrimorioEngine"
  }
}
